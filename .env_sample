# ==============================
# Telegram Bot
# ==============================
BOT_TOKEN=your_telegram_bot_token_here

# ==============================
# PostgreSQL Database
# ==============================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tarot_bot
DB_USER=postgres
DB_PASSWORD=your_password_here

# Полный DSN (собирается из переменных выше, но можно задать явно)
# DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/tarot_bot

# ==============================
# Bot Settings
# ==============================
# Режим работы: development / production
APP_ENV=development

# ID администратора бота (ваш Telegram user_id)
ADMIN_ID=123456789
